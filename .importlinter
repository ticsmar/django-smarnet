[importlinter]
root_packages =
    branch_auth
    shared
    users

[importlinter:contract:shared-domain-isolation]
name = Shared domain layer isolation
type = forbidden
source_modules =
    shared.domain
forbidden_modules =
    shared.application
    shared.infrastructure
    shared.presentation

[importlinter:contract:users-layers]
name = Users layer dependencies
type = layers
layers =
    users.presentation
    users.application
    users.domain

[importlinter:contract:users-domain-isolation]
name = Users domain layer isolation
type = forbidden
source_modules =
    users.domain
forbidden_modules =
    users.application
    users.infrastructure
    users.presentation

[importlinter:contract:users-app-no-presentation]
name = Users application cannot import presentation
type = forbidden
source_modules =
    users.application
forbidden_modules =
    users.presentation

[importlinter:contract:users-infra-boundary]
name = Users infrastructure boundary
type = forbidden
source_modules =
    users.infrastructure
forbidden_modules =
    users.application
    users.presentation

[importlinter:contract:shared-presentation-isolation]
name = Shared presentation cannot import domain modules
type = forbidden
source_modules =
    shared.presentation
forbidden_modules =
    users


[importlinter:contract:branch_auth-layers]
name = BranchAuth layer dependencies
type = layers
layers =
    branch_auth.presentation
    branch_auth.application
    branch_auth.domain

[importlinter:contract:branch_auth-domain-isolation]
name = BranchAuth domain layer isolation
type = forbidden
source_modules =
    branch_auth.domain
forbidden_modules =
    branch_auth.application
    branch_auth.infrastructure
    branch_auth.presentation

[importlinter:contract:branch_auth-app-no-presentation]
name = BranchAuth application cannot import presentation
type = forbidden
source_modules =
    branch_auth.application
forbidden_modules =
    branch_auth.presentation

[importlinter:contract:branch_auth-infra-boundary]
name = BranchAuth infrastructure boundary
type = forbidden
source_modules =
    branch_auth.infrastructure
forbidden_modules =
    branch_auth.application
    branch_auth.presentation
[importlinter:contract:domain-independence]
name = Domains are independent
type = independence
modules =
    branch_auth
    users
