# Oracle
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_SMAR_USER=
ORACLE_SMAR_PASSWORD=
# Oracle connection
ORACLE_HOST=
ORACLE_PORT=
ORACLE_SERVICE_NAME=
